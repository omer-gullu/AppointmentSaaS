@using Appointment_SaaS.Core.Constants
@{
    ViewData["Title"] = "Plan Seçin";
    ViewData["Description"] = "İşletmeniz için en uygun randevu yönetim planını seçin. Ücretsiz deneme ile hemen başlayın.";
    Layout = "_LayoutPricing";
}

<div class="pricing-page">
    <div class="container position-relative" style="z-index:1;">

        <!-- ── HEADER ── -->
        <div class="text-center au d0">
            <div class="pricing-kicker"><i class="bi bi-stars"></i> AI Destekli Randevu Sistemi</div>
            <h1 class="pricing-h1">
                İşletmenize özel<br><span class="grad">en doğru planı seçin</span>
            </h1>
            <p class="pricing-sub">
                Kurulum ücreti yok · Anında aktifleme<br>Her plan WhatsApp AI + Google Takvim entegrasyonu içerir
            </p>
            <div class="toggle-wrap au d1" id="billingWrap">
                <button class="toggle-btn active" id="btnMonthly" onclick="setBilling('monthly')">Aylık</button>
                <button class="toggle-btn" id="btnYearly" onclick="setBilling('yearly')">
                    Yıllık
                    <span class="save-label">%20 Tasarruf</span>
                </button>
            </div>
        </div>

        <!-- ── PLANS ── -->
        <div class="plans-grid mb-5">

            <!-- STARTER -->
            <div class="pcard au d2">
                <div class="pcard-name">Starter</div>
                <div class="pcard-price" id="amt-starter">@PlanPricing.StarterMonthly.ToString("N0")<sub> ₺/ay</sub></div>
                <div class="pcard-yearly-note" id="ynote-starter"></div>
                <p class="pcard-desc">Küçük ölçekli veya tek kişilik işletmeler için ideal başlangıç paketi.</p>

                <div class="pcard-limits">
                    <span class="lchip"><i class="bi bi-geo-alt-fill"></i> 1 Lokasyon</span>
                    <span class="lchip"><i class="bi bi-calendar-check"></i> 300 Randevu/Ay</span>
                    <span class="lchip"><i class="bi bi-person"></i> 1 Kullanıcı</span>
                </div>

                <ul class="flist">
                    <li><span class="fcheck"><i class="bi bi-check2"></i></span> WhatsApp AI Randevu Botu</li>
                    <li><span class="fcheck"><i class="bi bi-check2"></i></span> Randevu al / iptal / güncelle</li>
                    <li><span class="fcheck"><i class="bi bi-check2"></i></span> Google Takvim Senkronizasyonu</li>
                    <li><span class="fcheck"><i class="bi bi-check2"></i></span> Müşteri tanıma ve yönetimi</li>
                    <li class="off"><span class="fcheck"><i class="bi bi-x"></i></span> Buton formatı (WhatsApp menü)</li>
                    <li class="off"><span class="fcheck"><i class="bi bi-x"></i></span> İstatistik & raporlama paneli</li>
                    <li class="off"><span class="fcheck"><i class="bi bi-x"></i></span> Çoklu personel hesabı</li>
                </ul>

                <a href="/Auth/Register?plan=starter" id="link-starter" class="pcard-btn">
                    Bu Planı Seç <i class="bi bi-arrow-right ms-1"></i>
                </a>
                <p class="text-center mt-2 mb-0" style="font-size:0.68rem; color:#94a3b8;">
                    <i class="bi bi-arrow-repeat me-1"></i>İptal edilmediği sürece abonelik otomatik yenilenir.
                </p>
            </div>
            
           <!-- PRO -->
            <div class="pcard featured au d4">
                <div class="pcard-badge">⭐ En Çok Tercih Edilen</div>
                <div class="pcard-name">Pro</div>
                <div class="pcard-price" id="amt-pro">@PlanPricing.ProMonthly.ToString("N0")<sub> ₺/ay</sub></div>
                <div class="pcard-yearly-note" id="ynote-pro"></div>
                <p class="pcard-desc">Büyüyen işletmeler için sınırsız randevu ve gelişmiş özellikler.</p>

                <div class="pcard-limits">
                    <span class="lchip"><i class="bi bi-geo-alt-fill"></i> 1 Lokasyon</span>
                    <span class="lchip"><i class="bi bi-calendar-check"></i> Sınırsız</span>
                    <span class="lchip"><i class="bi bi-people"></i> 3 Kullanıcı</span>
                </div>

                <ul class="flist">
                    <li><span class="fcheck"><i class="bi bi-check2"></i></span> Starter'daki her şey</li>
                    <li><span class="fcheck"><i class="bi bi-check2"></i></span> 3 personel hesabı</li>
                    <li><span class="fcheck"><i class="bi bi-check2"></i></span> Öncelikli e-posta desteği</li>
                    <li><span class="fcheck"><i class="bi bi-check2"></i></span> Randevu hatırlatma mesajı</li>
                    <li class="off"><span class="fcheck"><i class="bi bi-x"></i></span> Çoklu lokasyon yönetimi</li>
                    <li class="off"><span class="fcheck"><i class="bi bi-check2"></i></span> İstatistik & raporlama paneli</li> 
                    <li class="off"><span class="fcheck"><i class="bi bi-check2"></i></span> No-show ve iptal raporları</li>
                </ul>

                <a href="/Auth/Register?plan=pro" id="link-pro" class="pcard-btn featured-btn">
                    <i class="bi bi-lightning-fill me-1"></i> Bu Planı Seç
                </a>
                <p class="text-center mt-2 mb-0" style="font-size:0.68rem; color:#a5b4fc;">
                    <i class="bi bi-arrow-repeat me-1"></i>İptal edilmediği sürece abonelik otomatik yenilenir.
                </p>
            </div>

@*             <!-- BUSINESS (featured) -->
            <div class="pcard au d4">
                <div class="pcard-name">Business</div>
                <div class="pcard-price" id="amt-business">@PlanPricing.ProMonthly.ToString("N0")<sub> ₺/ay</sub></div>
                <div class="pcard-yearly-note" id="ynote-business"></div>
                <p class="pcard-desc">Zincir işletmeler ve büyük ekipler için tam güç, öncelikli destek.</p>

                <div class="pcard-limits">
                    <span class="lchip"><i class="bi bi-geo-alt-fill"></i> 3 Lokasyon</span>
                    <span class="lchip"><i class="bi bi-calendar-check"></i> Sınırsız</span>
                    <span class="lchip"><i class="bi bi-people"></i> Sınırsız</span>
                </div>

                <ul class="flist">
                    <li><span class="fcheck"><i class="bi bi-check2"></i></span> Business'taki her şey</li>
                    <li><span class="fcheck"><i class="bi bi-check2"></i></span> 3 lokasyon yönetimi</li>
                    <li><span class="fcheck"><i class="bi bi-check2"></i></span> Sınırsız personel hesabı</li>
                    <li><span class="fcheck"><i class="bi bi-check2"></i></span> Gelişmiş istatistikler & API</li>
                    <li><span class="fcheck"><i class="bi bi-check2"></i></span> Özel onboarding desteği</li>
                    <li><span class="fcheck"><i class="bi bi-check2"></i></span> 7/24 öncelikli destek hattı</li>
                    <li><span class="fcheck"><i class="bi bi-check2"></i></span> Özel istekler & entegrasyon</li>
                </ul>

                <a href="/Auth/Register?plan=business" id="link-business" class="pcard-btn">
                    Bu Planı Seç <i class="bi bi-arrow-right ms-1"></i>
                </a>
                <p class="text-center mt-2 mb-0" style="font-size:0.68rem; color:#94a3b8;">
                    <i class="bi bi-arrow-repeat me-1"></i>İptal edilmediği sürece abonelik otomatik yenilenir.
                </p>
            </div> *@
        </div>

        <!-- ── TRIAL BANNER ── -->
        <div class="trial-section au d5 mb-5">
            <div class="row align-items-center g-4">
                <div class="col-md-8">
                    <div class="trial-title">🎁 14 Gün Ücretsiz Deneyin</div>
                    <div class="trial-sub">
                        Business özelliklerini 14 gün boyunca tam kullanın.<br>
                        <strong>⚠️ Önemli:</strong> Deneme süresi sonunda veya bir plan seçildiğinde,
                        <strong>aboneliğiniz iptal edilmediği sürece her ay otomatik olarak yenilenir.</strong>
                        İstediğiniz zaman panelden iptal edebilirsiniz.
                    </div>
                </div>
                <div class="col-md-4 text-md-end">
                    <a href="@(User.Identity?.IsAuthenticated == true ? "/Pricing/Upgrade?plan=trial" : "/Auth/Register?plan=trial")" class="btn-trial">
                        <i class="bi bi-play-fill"></i> Deneme Sürümünü Başlat
                    </a>
                </div>
            </div>
        </div>

        <!-- ── TRUST ── -->
        <div class="trust-row au d6">
            <div class="trust-item"><i class="bi bi-shield-check-fill"></i> SSL Güvenli</div>
            <div class="trust-item"><i class="bi bi-credit-card-fill"></i> İyzico ile Güvenli Ödeme</div>
            <div class="trust-item"><i class="bi bi-lock-fill"></i> KVKK Uyumlu</div>
            <div class="trust-item"><i class="bi bi-headset"></i> 7/24 Destek</div>
            <div class="trust-item"><i class="bi bi-arrow-counterclockwise"></i> İstediğin zaman iptal</div>
        </div>

    </div>
</div>

@section Scripts {
@{
    var pricingConfig = new {
        baseUrl = User.Identity?.IsAuthenticated == true ? "/Pricing/Upgrade" : "/Auth/Register",
        priceData = new {
            monthly = new {
                starter = new { amt = PlanPricing.StarterMonthly.ToString("N0"), note = "" },
                pro = new { amt = PlanPricing.ProMonthly.ToString("N0"), note = "" }
            },
            yearly = new {
                starter = new {
                    amt = PlanPricing.GetMonthlyEquivalentForYearly(PlanPricing.StarterYearly).ToString("N0"),
                    note = $"Yıllık ödemede {PlanPricing.StarterYearly:N0}₺ · <span class=\"save\">%20 Tasarruf</span>"
                },
                pro = new {
                    amt = PlanPricing.GetMonthlyEquivalentForYearly(PlanPricing.ProYearly).ToString("N0"),
                    note = $"Yıllık ödemede {PlanPricing.ProYearly:N0}₺ · <span class=\"save\">%20 Tasarruf</span>"
                }
            }
        }
    };
}
<script type="application/json" id="pricing-config">@Html.Raw(System.Text.Json.JsonSerializer.Serialize(pricingConfig))</script>
<script src="~/js/pricing-billing.js" asp-append-version="true" defer></script>
}
