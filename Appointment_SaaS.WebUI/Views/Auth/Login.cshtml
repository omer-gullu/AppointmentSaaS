@{
    ViewData["Title"] = "Giriş Yap";
    ViewData["Description"] = "Akıllı Randevu sistemine güvenli şifresiz giriş yapın. WhatsApp ile OTP doğrulama.";
    ViewData["RequireBootstrapIcons"] = true;
    Layout = "_LayoutAuth";
    var prefilledPhone = TempData["PrefilledPhone"] as string ?? string.Empty;
}
<div class="auth-page row justify-content-center align-items-center" style="min-height: 100vh; padding: 24px 16px;">
    <div class="col-12 col-md-8 col-lg-5">
        <div class="card premium-card border-0 shadow-lg" style="border-radius: 20px; overflow: hidden;">
            <div class="card-body p-5">
                <div class="text-center mb-5">
                    <div class="d-flex justify-content-center mb-3">
                        @{ ViewData["ArLogoSize"] = 96; ViewData["ArLogoVariant"] = "brand"; }
                        <partial name="_ArLogo" />
                    </div>
                    <h2 class="fw-bold mb-2">Hoş Geldiniz</h2>
                    <p class="text-muted" id="stepDescription">Sisteme giriş yapmak için telefon numaranızı girin.</p>
                </div>

                @if (Context.Request.Query.ContainsKey("sessionExpired"))
                {
                    <div class="alert alert-warning border-0 rounded-4 shadow-sm mb-4 d-flex align-items-center gap-2" role="alert">
                        <i class="bi bi-clock-history fs-5"></i>
                        <div>
                            <strong>Oturum süreniz dolmuştur.</strong><br>
                            Devam etmek için telefon numaranızla tekrar giriş yapın.
                        </div>
                    </div>
                }
                else if (Context.Request.Query.ContainsKey("suspended"))
                {
                    <div class="alert alert-danger border-0 rounded-4 shadow-sm mb-4 d-flex align-items-center gap-2" role="alert">
                        <i class="bi bi-exclamation-octagon-fill fs-5"></i>
                        <div>
                            <strong>Hesabınız askıya alınmıştır.</strong><br>
                            Lütfen yöneticiyle iletişime geçin.
                        </div>
                    </div>
                }
                @if (TempData["RegisterSuccess"] is string registerOk)
                {
                    <div class="alert alert-success border-0 rounded-4 shadow-sm mb-4" role="alert">
                        <i class="bi bi-check-circle-fill me-2"></i>@registerOk
                        @if (TempData["SetupTenantId"] != null)
                        {
                            <div class="mt-2">
                                <a asp-controller="Auth" asp-action="SetupFirstStaff" class="fw-bold">İlk personeli ekle →</a>
                            </div>
                        }
                    </div>
                }

                <!-- ADIM 1: TELEFON GİRİŞİ -->
                <div id="step1">
                    <form id="phoneForm" onsubmit="requestOtp(event)">
                        @Html.AntiForgeryToken()
                        <div class="form-floating mb-4 position-relative">
                            <input type="tel" class="form-control bg-light border-0 py-3" id="phoneNumber"
                                   placeholder="5xx xxx xx xx" required pattern="[0-9]{10,12}"
                                   value="@prefilledPhone"
                            @(string.IsNullOrEmpty(prefilledPhone) ? "" : "disabled")>
                            <label for="phoneNumber" class="text-muted"><i class="bi bi-phone me-2"></i>Telefon Numarası</label>
                            <div class="form-text mt-2">Şifresiz, güvenli giriş (WhatsApp üzerinden kod gönderilir)</div>
                        </div>

                        <button id="btnRequestOtp" type="submit" class="btn btn-primary w-100 py-3 rounded-pill fw-semibold shadow-sm d-flex justify-content-center align-items-center">
                            <span class="btn-text">Devam Et</span>
                            <div class="spinner-border spinner-border-sm text-light ms-2 d-none" role="status"></div>
                        </button>
                    </form>
                </div>

                <!-- ADIM 2: OTP DOĞRULAMA -->
                <div id="step2" class="d-none">
                    <form id="otpForm" onsubmit="verifyOtp(event)">
                        @Html.AntiForgeryToken()
                        <input type="hidden" id="loginPhone" value="" />
                        <div class="mb-4 text-center">
                            <label class="form-label text-muted mb-3">WhatsApp'a gönderilen 6 haneli kodu girin</label>

                            <div class="d-flex justify-content-between gap-2 mb-3" id="otpContainer">
                                <input type="text" class="form-control form-control-lg text-center fw-bold bg-light border-0 otp-input" maxlength="1" required autofocus>
                                <input type="text" class="form-control form-control-lg text-center fw-bold bg-light border-0 otp-input" maxlength="1" required>
                                <input type="text" class="form-control form-control-lg text-center fw-bold bg-light border-0 otp-input" maxlength="1" required>
                                <input type="text" class="form-control form-control-lg text-center fw-bold bg-light border-0 otp-input" maxlength="1" required>
                                <input type="text" class="form-control form-control-lg text-center fw-bold bg-light border-0 otp-input" maxlength="1" required>
                                <input type="text" class="form-control form-control-lg text-center fw-bold bg-light border-0 otp-input" maxlength="1" required>
                            </div>

                            <div id="otpCountdownWrap" class="mb-3">
                                <div class="d-inline-flex align-items-center gap-2 px-3 py-2 rounded-3"
                                     style="background: #fef3c7; border: 1px solid #fde68a;">
                                    <i class="bi bi-clock text-warning"></i>
                                    <span class="text-warning fw-bold small">Kodun geçerlilik süresi: <span id="countdownTimer">90</span>sn</span>
                                </div>
                            </div>
                            <div id="resendWrap" class="d-none mb-3">
                                <button type="button" class="btn btn-outline-secondary btn-sm rounded-pill px-4" onclick="resendOtp()">
                                    <i class="bi bi-arrow-clockwise me-1"></i>Kodu Tekrar Gönder
                                </button>
                            </div>
                        </div>

                        <button id="btnVerifyOtp" type="submit" class="btn btn-primary w-100 py-3 rounded-pill fw-semibold shadow-sm mb-3">
                            <span class="btn-text">Doğrula ve Giriş Yap</span>
                            <div class="spinner-border spinner-border-sm text-light ms-2 d-none" role="status"></div>
                        </button>

                        <div class="text-center">
                            <button type="button" class="btn btn-link text-decoration-none text-muted" onclick="backToStep1()">
                                <i class="bi bi-arrow-left me-1"></i> Numarayı Değiştir
                            </button>
                        </div>
                    </form>
                </div>

                <div id="errorMessage" class="alert alert-danger mt-4 d-none mb-0 flex-row align-items-center gap-2" role="alert">
                    <i class="bi bi-exclamation-triangle-fill"></i>
                    <span>Hata mesajı burada görünecek</span>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script src="~/js/login-page.js" asp-append-version="true" defer></script>
}
