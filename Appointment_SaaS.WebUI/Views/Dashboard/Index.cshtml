<!-- WhatsApp QR -->
<div class="modal fade" id="whatsAppModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content border-0 shadow-lg" style="border-radius:20px;">
            <div class="modal-header border-0 pb-0">
                <h5 class="fw-bold"><i class="bi bi-whatsapp text-success me-2"></i>WhatsApp Senkronizasyonu</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body text-center p-4 p-md-5">
                <div id="qrLoading">
                    <div class="spinner-border text-success mb-3" role="status" style="width:3rem;height:3rem;"></div>
                    <p class="text-muted">QR Kod Hazırlanıyor, lütfen bekleyin...</p>
                </div>
                <div id="qrContainer" style="display:none;">
                    <p class="small text-muted mb-4">Aşağıdaki QR kodu telefonunuzdan okutarak <strong id="modalInstanceName"></strong> dükkanını bağlayın.</p>
                    <div class="bg-white p-2 shadow-sm border rounded-4 d-inline-block mb-4">
                        <img id="qrImage" src="" class="img-fluid" style="width:250px;height:250px;" alt="WhatsApp QR">
                    </div>
                    <div class="text-start bg-light p-3 rounded-4 mb-4 small">
                        <ol class="mb-0">
                            <li>Telefonunuzda <b>WhatsApp</b>'ı açın.</li>
                            <li><b>Ayarlar</b> > <b>Bağlı Cihazlar</b>'a gidin.</li>
                            <li><b>Cihaz Bağla</b> butonuna dokunup bu kodu taratın.</li>
                        </ol>
                    </div>
                    <button onclick="loadWhatsAppQr()" class="btn btn-light rounded-pill w-100 border fw-bold">
                        <i class="bi bi-arrow-repeat me-2"></i> Kodu Yenile
                    </button>
                </div>
                <div id="qrError" style="display:none;" class="alert alert-warning border-0 small">
                    <i class="bi bi-info-circle-fill me-2"></i>
                    <span id="qrErrorMessage"></span>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Çalışma Saatleri Modal -->
<div class="modal fade" id="businessHoursModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered modal-md">
        <div class="modal-content border-0 shadow-lg" style="border-radius:20px;">
            <div class="modal-header border-bottom">
                <h5 class="fw-bold"><i class="bi bi-clock-history text-primary me-2"></i>Çalışma Saatleri</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body p-4">
                <form id="businessHoursForm">
                    <div class="d-flex flex-column gap-3">
                        @{
                            var allDays = new string[] { "Pazar", "Pazartesi", "Salı", "Çarşamba", "Perşembe", "Cuma", "Cumartesi" };
                            for (int i = 0; i < 7; i++)
                            {
                                bool hasBh = false;
                                System.Text.Json.JsonElement el = default;

                                if (Model.BusinessHours != null)
                                {
                                    foreach (var b in Model.BusinessHours)
                                    {
                                        if (b is System.Text.Json.JsonElement je)
                                        {
                                            if (je.TryGetProperty("dayOfWeek", out var dProp) && dProp.GetInt32() == i)
                                            {
                                                el = je;
                                                hasBh = true;
                                                break;
                                            }
                                        }
                                    }
                                }

                                bool isClosed = true;
                                string opTime = "09:00";
                                string clTime = "18:00";

                                if (hasBh)
                                {
                                    isClosed = el.TryGetProperty("isClosed", out var icProp) && icProp.GetBoolean();
                                    var opStr = el.TryGetProperty("openTime", out var opProp) ? opProp.GetString() : "09:00";
                                    var clStr = el.TryGetProperty("closeTime", out var clProp) ? clProp.GetString() : "18:00";
                                    if (opStr != null && opStr.Length > 5) opTime = opStr.Substring(0, 5);
                                    if (clStr != null && clStr.Length > 5) clTime = clStr.Substring(0, 5);
                                }
                                else if (i != 0 && i != 6)
                                {
                                    isClosed = false; // default hafta içi açık
                                }

                                <div class="row align-items-center bh-row" data-day="@i">
                                    <div class="col-4">
                                        <div class="form-check form-switch mb-0">
                                            <input class="form-check-input bh-status" type="checkbox" role="switch" id="bh_@i" @(!isClosed ? "checked" : "") onchange="toggleBhRow(@i)">
                                            <label class="form-check-label fw-medium" for="bh_@i">@allDays[i]</label>
                                        </div>
                                    </div>
                                    <div class="col-4">
                                        <input type="time" class="form-control form-control-sm bh-open" value="@opTime" @(isClosed ? "disabled" : "") />
                                    </div>
                                    <div class="col-4">
                                        <input type="time" class="form-control form-control-sm bh-close" value="@clTime" @(isClosed ? "disabled" : "") />
                                    </div>
                                </div>
                            }
                        }
                    </div>
                </form>
            </div>
            <div class="modal-footer border-top">
                <button type="button" class="btn btn-light rounded-pill" data-bs-dismiss="modal">İptal</button>
                <button type="button" class="btn btn-primary rounded-pill px-4" onclick="saveBusinessHours()">Kaydet</button>
            </div>
        </div>
    </div>
</div>

<form id="deleteAppointmentForm" asp-action="DeleteAppointment" asp-controller="Dashboard" method="post" class="d-none">
    <input type="hidden" id="deleteAppointmentId" name="appointmentId" />
    <input type="hidden" id="deleteGoogleEventId" name="googleEventId" />
    <input type="hidden" id="deleteAppUserId" name="appUserId" />
</form>

@section Scripts {
    <script>
        const waModal = new bootstrap.Modal(document.getElementById('whatsAppModal'));
        const editAppointmentModal = new bootstrap.Modal(document.getElementById('editAppointmentModal'));
        const editServiceModal = new bootstrap.Modal(document.getElementById('editServiceModal'));
        const businessHoursModal = new bootstrap.Modal(document.getElementById('businessHoursModal'));

        // ── Çalışma Saatleri ──
        function toggleBhRow(dayIndex) {
            const row = document.querySelector(`.bh-row[data-day="${dayIndex}"]`);
            const isChecked = row.querySelector('.bh-status').checked;
            row.querySelector('.bh-open').disabled = !isChecked;
            row.querySelector('.bh-close').disabled = !isChecked;
        }

        function saveBusinessHours() {
            const hours = [];
            document.querySelectorAll('.bh-row').forEach(row => {
                const day = parseInt(row.getAttribute('data-day'));
                const isClosed = !row.querySelector('.bh-status').checked;
                const openTime = row.querySelector('.bh-open').value;
                const closeTime = row.querySelector('.bh-close').value;

                hours.push({
                    dayOfWeek: day,
                    isClosed: isClosed,
                    openTime: openTime,
                    closeTime: closeTime
                });
            });

            fetch('/Dashboard/UpdateBusinessHours', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify(hours)
            })
            .then(res => res.json())
            .then(data => {
                if(data.success) {
                    swToast('success', data.message || 'Çalışma saatleri güncellendi.');
                    setTimeout(() => location.reload(), 1500);
                } else {
                    swToast('error', data.message || 'Bir hata oluştu.');
                }
            })
            .catch(err => swToast('error', 'Bağlantı hatası: ' + err));
        }

        // ── WhatsApp QR ──
        function loadWhatsAppQr() {
            const qrLoading = document.getElementById('qrLoading');
            const qrContainer = document.getElementById('qrContainer');
            const qrError = document.getElementById('qrError');
            const qrImage = document.getElementById('qrImage');

            qrLoading.style.display = 'block';
            qrContainer.style.display = 'none';
            qrError.style.display = 'block';
            document.getElementById('qrErrorMessage').innerText = 'Instance hazırlanıyor. QR kod için 5 saniye bekleniyor...';
            waModal.show();

            fetch('/Dashboard/GetWhatsAppQr')
                .then(res => res.json())
                .then(data => {
                    qrLoading.style.display = 'none';
                    if (data.success) {
                        qrError.style.display = 'none';
                        qrImage.src = data.qrCode;
                        document.getElementById('modalInstanceName').innerText = data.instanceName;
                        qrContainer.style.display = 'block';
                    } else {
                        qrError.style.display = 'block';
                        document.getElementById('qrErrorMessage').innerText = data.message;
                    }
                })
                .catch(() => {
                    qrLoading.style.display = 'none';
                    qrError.style.display = 'block';
                    document.getElementById('qrErrorMessage').innerText = 'Sistemle bağlantı kurulamadı.';
                });
        }

        // ── Randevu Düzenle ──
        function openEditAppointmentModal(id, customerName, customerPhone, serviceId, date, time, googleEventId, appUserId) {
            document.getElementById('editAppointmentId').value = id;
            document.getElementById('editGoogleEventId').value = googleEventId || '';
            document.getElementById('editAppUserId').value = appUserId || '';
            document.getElementById('editCustomerName').value = customerName;
            document.getElementById('editCustomerPhone').value = customerPhone;
            document.getElementById('editServiceId').value = serviceId;
            document.getElementById('editAppointmentDate').value = date;
            document.getElementById('editAppointmentTime').value = time;
            editAppointmentModal.show();
        }

        // ── Hizmet Düzenle ──
        function openEditServiceModal(serviceId, name, duration, price) {
            document.getElementById('editServiceIdInput').value = serviceId;
            document.getElementById('editServiceName').value = name;
            document.getElementById('editDuration').value = duration;
            document.getElementById('editPrice').value = price.replace(',', '.');
            editServiceModal.show();
        }

        // ── SweetAlert Toast ──
        function swToast(icon, title) {
            Swal.fire({
                toast: true, position: 'top-end', icon, title,
                showConfirmButton: false, timer: 3000, timerProgressBar: true,
                didOpen: (toast) => {
                    toast.addEventListener('mouseenter', Swal.stopTimer);
                    toast.addEventListener('mouseleave', Swal.resumeTimer);
                }
            });
        }

        // ── Randevu Validasyonu ──
        function validateCreateAppointment() {
            var name = document.getElementById('appCustomerName').value.trim();
            var phone = document.getElementById('appCustomerPhone').value.trim();
            if (!/^[a-zA-ZğüşıöçĞÜŞİÖÇ\s]+$/.test(name)) {
                Swal.fire('Hata!', 'Müşteri adı sadece harflerden oluşmalıdır.', 'warning');
                return false;
            }
            var numericPhone = phone.replace(/[^0-9]/g, '');
            if (numericPhone.length < 10 || numericPhone.length > 11) {
                Swal.fire('Hata!', 'Lütfen geçerli bir telefon numarası giriniz.', 'warning');
                return false;
            }
            return true;
        }

        // ── Randevu Sil ──
        document.querySelectorAll('.delete-appointment-form').forEach(form => {
            form.addEventListener('submit', function (e) {
                e.preventDefault();
                Swal.fire({
                    title: 'Randevuyu Sil', text: 'Bu randevuyu silmek istediğinize emin misiniz?',
                    icon: 'warning', showCancelButton: true,
                    confirmButtonColor: '#ef4444', cancelButtonColor: '#6b7280',
                    confirmButtonText: '<i class="bi bi-trash me-1"></i>Evet, Sil', cancelButtonText: 'İptal'
                }).then(r => { if (r.isConfirmed) this.submit(); });
            });
        });

        // ── Hizmet Sil ──
        document.querySelectorAll('.delete-service-form').forEach(form => {
            form.addEventListener('submit', function (e) {
                e.preventDefault();
                Swal.fire({
                    title: 'Hizmeti Sil', text: 'Bu hizmeti silmek istediğinize emin misiniz?',
                    icon: 'warning', showCancelButton: true,
                    confirmButtonColor: '#ef4444', cancelButtonColor: '#6b7280',
                    confirmButtonText: '<i class="bi bi-trash me-1"></i>Evet, Sil', cancelButtonText: 'İptal'
                }).then(r => { if (r.isConfirmed) this.submit(); });
            });
        });

        // ── Abonelik İptal ──
        document.getElementById('cancelSubscriptionForm')?.addEventListener('submit', function (e) {
            e.preventDefault();
            Swal.fire({
                title: 'Aboneliği İptal Et',
                html: '<p class="text-muted">Bu işlemi geri alamazsınız. Aboneliğiniz sonlandırılacak.</p>',
                icon: 'error', showCancelButton: true,
                confirmButtonColor: '#ef4444', cancelButtonColor: '#6b7280',
                confirmButtonText: 'Evet, İptal Et', cancelButtonText: 'Vazgeç'
            }).then(r => { if (r.isConfirmed) this.submit(); });
        });

        // ── AI Asistan Toggle ──
        document.getElementById('aiStatus').addEventListener('change', function () {
            const isActive = this.checked;
            const waConnected = @(Model.IsWhatsAppConnected ? "true" : "false");

            fetch('/Dashboard/ToggleAssistant', {
                method: 'POST',
                headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
                body: `isActive=${isActive}`
            })
                .then(res => res.json())
                .then(data => {
                    if (!data.success) {
                        this.checked = !isActive;
                        swToast('error', 'AI asistan durumu güncellenemedi.');
                        return;
                    }
                    const isWa = data.isWhatsAppConnected !== undefined ? data.isWhatsAppConnected : waConnected;
                    document.getElementById('aiStatusText').innerText = isActive ? '7/24 Aktif' : 'Devre Dışı';
                    const badge = document.getElementById('systemBadge');
                    if (badge) {
                        if (!isActive) { badge.style.background = '#f1f5f9'; badge.style.color = '#94a3b8'; badge.textContent = 'Pasif'; }
                        else if (isWa) { badge.style.background = '#dcfce7'; badge.style.color = '#16a34a'; badge.textContent = 'Hazır ✅'; }
                        else { badge.style.background = '#fef9c3'; badge.style.color = '#b45309'; badge.textContent = '⚠️ Bekliyor'; }
                    }
                    document.querySelectorAll('#aiWarningBox').forEach(box => {
                        if (isActive && !isWa) {
                            box.classList.remove('d-none');
                            const waCard = document.getElementById('whatsappCard');
                            if (waCard) {
                                waCard.classList.add('pulse-warning');
                                setTimeout(() => waCard.scrollIntoView({ behavior: 'smooth', block: 'center' }), 350);
                                setTimeout(() => waCard.classList.remove('pulse-warning'), 6000);
                            }
                        } else {
                            box.classList.add('d-none');
                            document.getElementById('whatsappCard')?.classList.remove('pulse-warning');
                        }
                    });
                    const toastMsg = isActive && !isWa ? "AI Asistan aktifleşti — lütfen WhatsApp'ı bağlayın." : (isActive ? 'AI Asistan aktifleştirildi.' : 'AI Asistan devre dışı bırakıldı.');
                    swToast(isActive && !isWa ? 'warning' : 'success', toastMsg);
                })
                .catch(() => { this.checked = !isActive; swToast('error', 'Sistemle bağlantı kurulamadı.'); });
        });

        // ── Personel Ekle ──
        async function addStaff() {
            const nameParts = document.getElementById('staffFullName').value.trim().split(' ');
            const firstName = nameParts.slice(0, -1).join(' ') || nameParts[0];
            const lastName = nameParts.length > 1 ? nameParts[nameParts.length - 1] : '';
            const payload = {
                firstName,
                lastName,
                email: ('staff_' + Date.now() + "@@personel.local"),
                phoneNumber: document.getElementById('staffPhone').value.trim(),
                specialization: document.getElementById('staffSpec').value.trim(),
                googleCalendarId: null
            };
            try {
                const res = await fetch('/Dashboard/AddStaff', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify(payload)
                });
                const data = await res.json();
                if (res.ok) {
                    bootstrap.Modal.getInstance(document.getElementById('addStaffModal')).hide();
                    swToast('success', 'Personel başarıyla eklendi.');
                    setTimeout(() => location.reload(), 1200);
                } else if (res.status === 403 && data.upgradeRequired) {
                    bootstrap.Modal.getInstance(document.getElementById('addStaffModal')).hide();
                    Swal.fire({
                        icon: 'warning', title: 'Plan Limiti',
                        html: `${data.message || data.Message}<br><br><a href="/Auth/Plans" class="btn btn-primary rounded-pill px-4 mt-2">Planı Yükselt</a>`,
                        confirmButtonText: 'Tamam', confirmButtonColor: '#6366f1'
                    });
                } else {
                    swToast('error', data.message || data.Message || 'Personel eklenemedi.');
                }
            } catch { swToast('error', 'Sistemle bağlantı kurulamadı.'); }
        }

        // ── Personel Sil ──
        async function removeStaff(userId) {
            const result = await Swal.fire({
                title: 'Personeli Sil', text: 'Bu personeli silmek istediğinize emin misiniz?',
                icon: 'warning', showCancelButton: true,
                confirmButtonColor: '#ef4444', cancelButtonColor: '#6b7280',
                confirmButtonText: 'Evet, Sil', cancelButtonText: 'İptal'
            });
            if (!result.isConfirmed) return;
            try {
                const res = await fetch(`/Dashboard/RemoveStaff?userId=${userId}`, { method: 'DELETE' });
                if (res.ok) { swToast('success', 'Personel silindi.'); setTimeout(() => location.reload(), 1200); }
                else { swToast('error', 'Personel silinemedi.'); }
            } catch { swToast('error', 'Sistemle bağlantı kurulamadı.'); }
        }
    </script>
}
