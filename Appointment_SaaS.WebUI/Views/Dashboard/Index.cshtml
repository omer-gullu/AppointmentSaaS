    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content border-0 shadow" style="border-radius:20px;">
            <div class="modal-header border-0 pb-0">
                <h5 class="fw-bold"><i class="bi bi-calendar-plus me-2 text-primary"></i>Hızlı Randevu Kaydı</h5>
                <button type="button" class="btn-close shadow-none" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body p-4">
                <form asp-action="CreateAppointment" asp-controller="Dashboard" method="post" onsubmit="return validateCreateAppointment()">
                    <div class="mb-3">
                        <label class="form-label text-muted small fw-bold">MÜŞTERİ ADI</label>
                        <input type="text" name="customerName" id="appCustomerName" class="form-control bg-light border-0 py-2" placeholder="Ad Soyad" required>
                    </div>
                    <div class="mb-3">
                        <label class="form-label text-muted small fw-bold">TELEFON</label>
                        <input type="tel" name="customerPhone" id="appCustomerPhone" class="form-control bg-light border-0 py-2" placeholder="05XX XXX XX XX" required>
                    </div>
                    <div class="mb-3">
                        <label class="form-label text-muted small fw-bold">HİZMET</label>
                        <select name="serviceId" class="form-select bg-light border-0 py-2" required>
                            @if (Model.Services != null && Model.Services.Count > 0)
                            {
                                @foreach (var s in Model.Services)
                                {
                                    <option value="@s.GetProperty("serviceID")">@s.GetProperty("name") (@s.GetProperty("durationInMinutes") dk)</option>
                                }
                            }
                            else
                            {
                                <option value="">Önce hizmet tanımlayın</option>
                            }
                        </select>
                    </div>
                    <div class="row g-3 mb-3">
                        <div class="col-6">
                            <label class="form-label text-muted small fw-bold">TARİH</label>
                            <input type="date" name="date" class="form-control bg-light border-0 py-2" required value="@DateTime.Now.ToString("yyyy-MM-dd")" min="@DateTime.Now.ToString("yyyy-MM-dd")">
                        </div>
                        <div class="col-6">
                            <label class="form-label text-muted small fw-bold">SAAT</label>
                            <input type="time" name="time" class="form-control bg-light border-0 py-2" required value="10:00">
                        </div>
                    </div>
                    <button type="submit" class="btn btn-primary w-100 py-3 rounded-pill fw-bold shadow-sm mt-3">Randevuyu Kaydet</button>
                </form>
            </div>
        </div>
    </div>
</div>

