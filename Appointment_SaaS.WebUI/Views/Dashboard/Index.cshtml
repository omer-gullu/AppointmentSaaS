                        </div>
                        <div class="col-6">
                            <label class="form-label text-muted small fw-bold">SAAT</label>
                            <input type="time" id="editAppointmentTime" name="time" class="form-control bg-light border-0 py-2" required>
                        </div>
                    </div>
                    <button type="submit" class="btn btn-primary w-100 py-3 rounded-pill fw-bold shadow-sm mt-3">Randevuyu Güncelle</button>
                </form>
            </div>
        </div>
    </div>
</div>

