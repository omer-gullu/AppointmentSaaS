                    </div>
                    <div class="mb-3">
                        <label class="form-label text-muted small fw-bold">HİZMET</label>
                        <select id="editServiceId" name="serviceId" class="form-select bg-light border-0 py-2" required>
                            @if (Model.Services != null)
                            {
                                @foreach (var s in Model.Services)
                                {
                                    <option value="@s.GetProperty("serviceID")">@s.GetProperty("name") (@s.GetProperty("durationInMinutes") dk)</option>
                                }
                            }
                        </select>
                    </div>
                    <div class="mb-3">
                        <label class="form-label text-muted small fw-bold">PERSONEL SEÇİMİ</label>
                        <select id="editAppUserIdSelect" name="appUserId" class="form-select bg-light border-0 py-2" required>
                            <option value="">Personel Seçin</option>
                            @if (Model.Staff != null)
                            {
                                @foreach (var s in Model.Staff)
                                {
                                    <option value="@s.GetProperty("appUserID")">@s.GetProperty("firstName") @s.GetProperty("lastName")</option>
                                }
                            }
                        </select>
