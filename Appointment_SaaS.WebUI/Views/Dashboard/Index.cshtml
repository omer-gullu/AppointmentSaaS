<!-- Randevu Düzenle -->
<div class="modal fade" id="editAppointmentModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content border-0 shadow" style="border-radius:20px;">
            <div class="modal-header border-0 pb-0">
                <h5 class="fw-bold"><i class="bi bi-pencil-square me-2 text-primary"></i>Randevu Düzenle</h5>
                <button type="button" class="btn-close shadow-none" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body p-4">
                <form asp-action="UpdateAppointment" asp-controller="Dashboard" method="post">
                    <input type="hidden" id="editAppointmentId" name="appointmentId" />
                    <input type="hidden" id="editGoogleEventId" name="googleEventId" />
                    <input type="hidden" id="editAppUserId" name="appUserId" />
                    <div class="mb-3">
                        <label class="form-label text-muted small fw-bold">MÜŞTERİ ADI</label>
                        <input type="text" id="editCustomerName" name="customerName" class="form-control bg-light border-0 py-2" required>
                    </div>
                    <div class="mb-3">
                        <label class="form-label text-muted small fw-bold">TELEFON</label>
                        <input type="tel" id="editCustomerPhone" name="customerPhone" class="form-control bg-light border-0 py-2" required>
                    </div>
                    <div class="mb-3">
                        <label class="form-label text-muted small fw-bold">HİZMET</label>
                        <select id="editServiceId" name="serviceId" class="form-select bg-light border-0 py-2" required>
                            @if (Model.Services != null)
                            {
                                @foreach (var s in Model.Services)
                                {
                                    <option value="@s.GetProperty("serviceID")">@s.GetProperty("name") (@s.GetProperty("durationInMinutes") dk)</option>
                                }
                            }
                        </select>
                    </div>
                    <div class="row g-3 mb-3">
                        <div class="col-6">
                            <label class="form-label text-muted small fw-bold">TARİH</label>
                            <input type="date" id="editAppointmentDate" name="date" class="form-control bg-light border-0 py-2" required>
                        </div>
                        <div class="col-6">
                            <label class="form-label text-muted small fw-bold">SAAT</label>
                            <input type="time" id="editAppointmentTime" name="time" class="form-control bg-light border-0 py-2" required>
                        </div>
                    </div>
                    <button type="submit" class="btn btn-primary w-100 py-3 rounded-pill fw-bold shadow-sm mt-3">Randevuyu Güncelle</button>
                </form>
            </div>
        </div>
    </div>
</div>

<!-- Hizmet Düzenle -->
<div class="modal fade" id="editServiceModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content border-0 shadow" style="border-radius:20px;">
            <div class="modal-header border-0 pb-0">
                <h5 class="fw-bold"><i class="bi bi-pencil-square me-2 text-success"></i>Hizmet Düzenle</h5>
                <button type="button" class="btn-close shadow-none" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body p-4">
                <form asp-action="UpdateService" asp-controller="Dashboard" method="post">
