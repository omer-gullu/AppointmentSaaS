<!-- Çalışma Saatleri Modal -->
<div class="modal fade" id="businessHoursModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered modal-md">
        <div class="modal-content border-0 shadow-lg" style="border-radius:20px;">
            <div class="modal-header border-bottom">
                <h5 class="fw-bold"><i class="bi bi-clock-history text-primary me-2"></i>Çalışma Saatleri</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body p-4">
                <form id="businessHoursForm">
                    @Html.AntiForgeryToken()
                    <div class="d-flex flex-column gap-3">
                        @{
                            var allDays = new string[] { "Pazar", "Pazartesi", "Salı", "Çarşamba", "Perşembe", "Cuma", "Cumartesi" };
                            for (int i = 0; i < 7; i++)
                            {
                                bool hasBh = false;
                                System.Text.Json.JsonElement el = default;

                                if (Model.BusinessHours != null)
                                {
                                    foreach (var b in Model.BusinessHours)
                                    {
                                        if (b is System.Text.Json.JsonElement je)
                                        {
                                            if (je.TryGetProperty("dayOfWeek", out var dProp) && dProp.GetInt32() == i)
                                            {
                                                el = je;
                                                hasBh = true;
                                                break;
                                            }
                                        }
                                    }
                                }

                                bool isClosed = true;
                                string opTime = "09:00";
                                string clTime = "18:00";

                                if (hasBh)
                                {
                                    isClosed = el.TryGetProperty("isClosed", out var icProp) && icProp.GetBoolean();
                                    var opStr = el.TryGetProperty("openTime", out var opProp) ? opProp.GetString() : "09:00";
                                    var clStr = el.TryGetProperty("closeTime", out var clProp) ? clProp.GetString() : "18:00";
                                    if (opStr != null && opStr.Length > 5) opTime = opStr.Substring(0, 5);
                                    if (clStr != null && clStr.Length > 5) clTime = clStr.Substring(0, 5);
                                }
                                else if (i != 0 && i != 6)
                                {
                                    isClosed = false; // default hafta içi açık
                                }

                                <div class="row align-items-center bh-row" data-day="@i">
                                    <div class="col-4">
                                        <div class="form-check form-switch mb-0">
                                            <input class="form-check-input bh-status" type="checkbox" role="switch" id="bh_@i" @(!isClosed ? "checked" : "") onchange="toggleBhRow(@i)">
                                            <label class="form-check-label fw-medium" for="bh_@i">@allDays[i]</label>
                                        </div>
                                    </div>
                                    <div class="col-4">
                                        <input type="time" class="form-control form-control-sm bh-open" value="@opTime" @(isClosed ? "disabled" : "") />
                                    </div>
                                    <div class="col-4">
                                        <input type="time" class="form-control form-control-sm bh-close" value="@clTime" @(isClosed ? "disabled" : "") />
                                    </div>
                                </div>
                            }
                        }
                    </div>
                </form>
            </div>
            <div class="modal-footer border-top">
                <button type="button" class="btn btn-outline-secondary rounded-pill px-4" data-bs-dismiss="modal">İptal</button>
                <button type="button" class="btn btn-primary rounded-pill px-4 fw-bold" onclick="saveBusinessHours()">Kaydet</button>
            </div>
        </div>
    </div>
</div>

