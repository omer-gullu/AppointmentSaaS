{
  "name": "appointment-saas-e2e",
  "private": true,
  "version": "1.0.0",
  "description": "Playwright E2E tests for Appointment SaaS",
  "scripts": {
    "test": "playwright test",
    "test:headed": "playwright test --headed",
    "test:ui": "playwright test --ui",
    "test:smoke": "playwright test --config=playwright.smoke.config.ts",
    "test:appointment": "playwright test tests/appointment.spec.ts",
    "test:payment": "playwright test tests/payment.spec.ts",
    "test:security": "playwright test tests/security.spec.ts",
    "test:register": "playwright test tests/register-checkout.spec.ts",
    "test:load:appointments": "k6 run load-tests/appointment-load.js",
    "test:load:webhook": "powershell -ExecutionPolicy Bypass -File scripts/run-k6.ps1 -Script load-tests/n8n-webhook-load.js",
    "test:load:webhook:light": "powershell -ExecutionPolicy Bypass -File scripts/run-k6.ps1 -Script load-tests/n8n-webhook-load.js -Scenario load -LoadVus 10",
    "test:load:webhook:legacy": "powershell -ExecutionPolicy Bypass -File scripts/run-k6.ps1 -Script load-tests/whatsapp-webhook-load.js",
    "test:load:race": "powershell -ExecutionPolicy Bypass -File scripts/run-k6.ps1 -Script load-tests/n8n-webhook-load.js -Scenario race",
    "test:load:ai": "cross-env E2E_RUN_LOAD_AI=true k6 run load-tests/ai-response-load.js",
    "test:load": "npm run test:load:appointments",
    "test:billing": "playwright test tests/billing.spec.ts",
    "test:n8n": "playwright test tests/n8n-contract.spec.ts tests/n8n-workflow.spec.ts",
    "test:n8n:contract": "playwright test tests/n8n-contract.spec.ts",
    "test:api": "playwright test tests/n8n-contract.spec.ts tests/appointment.spec.ts tests/appointment-mutations.spec.ts --grep \"API|n8n API\"",
    "test:n8n:live": "playwright test tests/n8n-workflow.spec.ts",
    "test:n8n:behavior": "playwright test tests/n8n-behavior.spec.ts",
    "test:mutations": "playwright test tests/appointment-mutations.spec.ts",
    "test:n8n:gemini": "cross-env E2E_RUN_GEMINI=true playwright test tests/n8n-gemini.spec.ts",
    "test:n8n:ai-edge": "cross-env E2E_RUN_AI_EDGE=true playwright test tests/n8n-ai-edge-cases.spec.ts",
    "test:gemini": "npm run test:n8n:gemini",
    "test:dev": "cross-env PLAYWRIGHT_ENV=development playwright test",
    "test:staging": "cross-env PLAYWRIGHT_ENV=staging playwright test",
    "test:production": "cross-env PLAYWRIGHT_ENV=production playwright test",
    "report": "playwright show-report",
    "install:browsers": "playwright install chromium",
    "sync:env": "node scripts/sync-env.mjs"
  },
  "devDependencies": {
    "@playwright/test": "^1.50.0",
    "@types/mssql": "^9.1.5",
    "@types/node": "^22.10.0",
    "cross-env": "^7.0.3",
    "dotenv": "^16.6.1",
    "mssql": "^11.0.1",
    "typescript": "^5.7.2"
  }
}
