{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "ConnectionStrings": {
    "DefaultConnection": "__CONNECTION_STRING_FROM_ENV__"
  },
  "TokenOptions": {
    "Audience": "www.appointment-saas.com",
    "Issuer": "www.appointment-saas.com",
    "AccessTokenExpiration": 14400,
    "SecurityKey": "__JWT_SECRET_FROM_ENV__"
  },
  "EvolutionApi": {
    "BaseUrl": "__EVOLUTION_API_URL_FROM_ENV__",
    "GlobalApiKey": "__EVOLUTION_API_KEY_FROM_ENV__",
    "WebhookUrl": "__WEBHOOK_URL_FROM_ENV__",
    "DefaultInstance": "__DEFAULT_INSTANCE_FROM_ENV__"
  },
  "Google": {
    "ClientId": "__GOOGLE_CLIENT_ID_FROM_ENV__",
    "ClientSecret": "__GOOGLE_CLIENT_SECRET_FROM_ENV__",
    "RedirectUri": "__GOOGLE_REDIRECT_URI_FROM_ENV__"
  },
  "WebhookSecurity": {
    "N8nAuthToken": "__N8N_WEBHOOK_TOKEN_FROM_ENV__"
  },
  "EncryptionSettings": {
    "AesKey": "__AES256_KEY_FROM_ENV__"
  },
  "IyzicoSettings": {
    "Enabled": false,
    "ApiKey": "__IYZICO_API_KEY_FROM_ENV__",
    "SecretKey": "__IYZICO_SECRET_KEY_FROM_ENV__",
    "BaseUrl": "https://sandbox-api.iyzipay.com",
    "PricingPlanReferenceCode": "__IYZICO_PRICING_PLAN_REF_FROM_ENV__",
    "WebhookSecret": "__IYZICO_WEBHOOK_SECRET_FROM_ENV__"
  },
  "LockoutSettings": {
    "MaxFailedAccessAttempts": 5,
    "DefaultLockoutTimeSpanInMinutes": 10
  },
  "CorsSettings": {
    "AllowedOrigins": [
      "https://yourdomain.com",
      "http://localhost:5259"
    ]
  },
  "IpRateLimiting": {
    "EnableEndpointRateLimiting": true,
    "StackBlockedRequests": false,
    "HttpStatusCode": 429,
    "GeneralRules": [
      {
        "Endpoint": "POST:/api/auth/*",
        "Period": "1m",
        "Limit": 5
      },
      {
        "Endpoint": "POST:/api/appointments",
        "Period": "1m",
        "Limit": 20
      },
      {
        "Endpoint": "*",
        "Period": "1m",
        "Limit": 100
      }
    ]
  }
}