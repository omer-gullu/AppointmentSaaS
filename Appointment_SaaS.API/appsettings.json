{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "SubscriptionBilling": {
    "RenewalGraceHours": 12
  },
  "ConnectionStrings": {
    "DefaultConnection": "__CONNECTION_STRING_FROM_ENV__"
  },
  "TokenOptions": {
    "Audience": "www.appointment-saas.com",
    "Issuer": "www.appointment-saas.com",
    "AccessTokenExpiration": 480,
    "SecurityKey": "__JWT_SECRET_FROM_ENV__"
  },
  "EvolutionApi": {
    "BaseUrl": "__EVOLUTION_API_URL_FROM_ENV__",
    "GlobalApiKey": "__EVOLUTION_API_KEY_FROM_ENV__",
    "WebhookUrl": "__WEBHOOK_URL_FROM_ENV__",
    "DefaultInstance": "__DEFAULT_INSTANCE_FROM_ENV__",
    "SandboxPhonePrefixes": [ "905320000" ],
    "EnforceWhatsAppAllowlist": false,
    "AllowedWhatsAppNumbers": []
  },
  "Google": {
    "ClientId": "__GOOGLE_CLIENT_ID_FROM_ENV__",
    "ClientSecret": "__GOOGLE_CLIENT_SECRET_FROM_ENV__",
    "RedirectUri": "__GOOGLE_REDIRECT_URI_FROM_ENV__"
  },
  "WebhookSecurity": {
    "N8nAuthToken": "__N8N_WEBHOOK_TOKEN_FROM_ENV__"
  },
  "EncryptionSettings": {
    "AesKey": "__AES256_KEY_FROM_ENV__"
  },
  "IyzicoSettings": {
    "Enabled": false,
    "ApiKey": "__IYZICO_API_KEY_FROM_ENV__",
    "SecretKey": "__IYZICO_SECRET_KEY_FROM_ENV__",
    "BaseUrl": "https://api.iyzipay.com",
    "StarterMonthlyPlanCode": "__IYZICO_STARTER_MONTHLY_PLAN_REF__",
    "StarterYearlyPlanCode": "__IYZICO_STARTER_YEARLY_PLAN_REF__",
    "BusinessMonthlyPlanCode": "__IYZICO_BUSINESS_MONTHLY_PLAN_REF__",
    "BusinessYearlyPlanCode": "__IYZICO_BUSINESS_YEARLY_PLAN_REF__",
    "ProMonthlyPlanCode": "__IYZICO_PRO_MONTHLY_PLAN_REF__",
    "ProYearlyPlanCode": "__IYZICO_PRO_YEARLY_PLAN_REF__",
    "WebhookSecret": "__IYZICO_WEBHOOK_SECRET_FROM_ENV__",
    "TrialCardValidationAmountTry": 1.0,
    "RefundCallerIp": "127.0.0.1"
  },
  "LockoutSettings": {
    "MaxFailedAccessAttempts": 5,
    "DefaultLockoutTimeSpanInMinutes": 10
  },
  "CorsSettings": {
    "AllowedOrigins": [
      "https://yourdomain.com",
      "http://localhost:5259"
    ]
  },
  "IpRateLimiting": {
    "EnableEndpointRateLimiting": true,
    "StackBlockedRequests": false,
    "HttpStatusCode": 429,
    "GeneralRules": [
      {
        "Endpoint": "POST:/api/auth/generate-otp",
        "Period": "1m",
        "Limit": 3
      },
      {
        "Endpoint": "POST:/api/auth/verify-otp",
        "Period": "1m",
        "Limit": 10
      },
      {
        "Endpoint": "POST:/api/auth/*",
        "Period": "1m",
        "Limit": 5
      },
      {
        "Endpoint": "POST:/api/auth/payment-callback",
        "Period": "1m",
        "Limit": 10
      },
      {
        "Endpoint": "POST:/api/appointments/lock",
        "Period": "1m",
        "Limit": 30
      },
      {
        "Endpoint": "POST:/api/appointments/unlock",
        "Period": "1m",
        "Limit": 30
      },
      {
        "Endpoint": "POST:/api/feedbacks",
        "Period": "1m",
        "Limit": 10
      },
      {
        "Endpoint": "POST:/api/whatsappblockedphones/opt-out",
        "Period": "1m",
        "Limit": 15
      },
      {
        "Endpoint": "GET:/api/whatsappblockedphones/check",
        "Period": "1m",
        "Limit": 60
      },
      {
        "Endpoint": "POST:/api/appointments",
        "Period": "1m",
        "Limit": 20
      },
      {
        "Endpoint": "*",
        "Period": "1m",
        "Limit": 100
      }
    ]
  }
}